{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UplinkCredential",
  "type": "object",
  "$metadata": {
    "uris": {
      "jsonLdContext": "https://raw.githubusercontent.com/deaiyuki/Review/main/uplink.context.json",
      "jsonSchema": "https://raw.githubusercontent.com/deaiyuki/Review/main/uplink.schema.json"
    }
  },
  "required": [
    "@context",
    "type",
    "issuer",
    "issuanceDate",
    "credentialSubject",
    "credentialSchema"
  ],
  "properties": {
    "@context": {
      "type": ["array", "string"]
    },
    "id": {
      "type": "string"
    },
    "type": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": { "type": "string" }
        }
      ]
    },
    "issuer": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "issuanceDate": {
      "type": "string",
      "format": "date-time"
    },
    "expirationDate": {
      "type": "string",
      "format": "date-time"
    },
    "credentialSchema": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "credentialSubject": {
      "type": "object",
      "required": [
        "id",
        "linkedPrivadoDid",
        "relationship",
        "linkageMethod",
        "linkedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "UP DID"
        },
        "linkedPrivadoDid": {
          "type": "string",
          "description": "Linked Privado DID"
        },
        "relationship": {
          "type": "string",
          "enum": ["linked-in-application"]
        },
        "linkageMethod": {
          "type": "string",
          "enum": [
            "authentication-based-linkage",
            "up-signature-and-privado-authentication"
          ]
        },
        "linkedAt": {
          "type": "string",
          "format": "date-time"
        },
        "evidenceSummary": {
          "type": "object",
          "properties": {
            "upSignatureVerified": {
              "type": "boolean"
            },
            "privadoAuthenticationVerified": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "proof": {
      "type": "object"
    },
    "proofs": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
