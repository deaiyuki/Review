{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UPLinkCredential",
  "type": "object",
  "$metadata": {
    "uris": {
      "jsonLdContext": "https://raw.githubusercontent.com/deaiyuki/Review/main/uplink.jsonld",
      "jsonSchema": "https://raw.githubusercontent.com/deaiyuki/Review/main/uplink.schema.json"
    }
  },
  "required": [
    "@context",
    "type",
    "issuer",
    "issuanceDate",
    "expirationDate",
    "credentialSchema",
    "credentialSubject"
  ],
  "properties": {
    "@context": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": ["string", "object"]
          }
        }
      ]
    },
    "type": {
      "oneOf": [
        {
          "type": "string",
          "const": "UPLinkCredential"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          },
          "allOf": [
            {
              "contains": {
                "const": "VerifiableCredential"
              }
            },
            {
              "contains": {
                "const": "UPLinkCredential"
              }
            }
          ]
        }
      ]
    },
    "issuer": {
      "type": "string",
      "pattern": "^did:"
    },
    "issuanceDate": {
      "type": "string",
      "format": "date-time"
    },
    "expirationDate": {
      "type": "string",
      "format": "date-time"
    },
    "credentialSchema": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uri"
        },
        "type": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "credentialSubject": {
      "type": "object",
      "required": [
        "id",
        "linkedPrivadoDid",
        "relationship",
        "linkageMethod",
        "linkedAt",
        "evidenceSummary"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^did:"
        },
        "linkedPrivadoDid": {
          "type": "string",
          "pattern": "^did:"
        },
        "relationship": {
          "type": "string"
        },
        "linkageMethod": {
          "type": "string"
        },
        "linkedAt": {
          "type": "string",
          "format": "date-time"
        },
        "evidenceSummary": {
          "type": "object",
          "required": [
            "upSignatureVerified",
            "privadoAuthenticationVerified"
          ],
          "properties": {
            "upSignatureVerified": {
              "type": "boolean"
            },
            "privadoAuthenticationVerified": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "proof": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
