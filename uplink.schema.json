{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UPLinkCredential",
  "type": "object",
  "$metadata": {
    "uris": {
      "jsonLdContext": "https://raw.githubusercontent.com/deaiyuki/Review/main/uplink.json",
      "jsonSchema": "https://raw.githubusercontent.com/deaiyuki/Review/main/uplink.schema.json"
    }
  },
  "required": ["type", "credentialSubject"],
  "properties": {
    "type": {
      "oneOf": [
        {
          "type": "string",
          "const": "UPLinkCredential"
        },
        {
          "type": "array",
          "items": { "type": "string" },
          "contains": { "const": "UPLinkCredential" }
        }
      ]
    },
    "credentialSchema": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uri"
        },
        "type": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "credentialSubject": {
      "type": "object",
      "required": [
        "id",
        "upDid",
        "upAddress",
        "privadoProof",
        "sessionId",
        "message",
        "signature"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uri"
        },
        "upDid": {
          "type": "string",
          "format": "uri"
        },
        "upAddress": {
          "type": "string"
        },
        "privadoProof": {
          "type": ["object", "string", "array"]
        },
        "sessionId": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "signature": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "proof": {
      "type": "object"
    },
    "proofs": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
