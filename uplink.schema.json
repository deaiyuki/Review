{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UPLinkCredential",
  "type": "object",
  "$metadata": {
    "uris": {
      "jsonLdContext": "https://raw.githubusercontent.com/deaiyuki/Review/main/uplink.jsonld",
      "jsonSchema": "https://raw.githubusercontent.com/deaiyuki/Review/main/uplink.schema.json"
    }
  },
  "required": ["type", "credentialSubject"],
  "properties": {
    "type": {
      "oneOf": [
        { "type": "string", "const": "UPLinkCredential" },
        {
          "type": "array",
          "items": { "type": "string" },
          "contains": { "const": "UPLinkCredential" }
        }
      ]
    },
    "credentialSchema": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": { "type": "string", "format": "uri" },
        "type": { "type": "string" }
      },
      "additionalProperties": true
    },
    "credentialSubject": {
      "type": "object",
      "required": [
        "id",
        "linkedPrivadoDid",
        "relationship",
        "linkageMethod",
        "linkedAt",
        "upSignatureVerified",
        "privadoAuthenticationVerified"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^did:"
        },
        "linkedPrivadoDid": {
          "type": "string",
          "pattern": "^did:"
        },
        "relationship": {
          "type": "string"
        },
        "linkageMethod": {
          "type": "string"
        },
        "linkedAt": {
          "type": "string",
          "format": "date-time"
        },
        "upSignatureVerified": {
          "type": "boolean"
        },
        "privadoAuthenticationVerified": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "expiration": {
      "type": "integer",
      "minimum": 0
    },
    "proof": {
      "type": "object"
    },
    "proofs": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
