{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UPLinkCredential",
  "type": "object",
  "$metadata": {
    "uris": {
      "jsonLdContext": "https://raw.githubusercontent.com/deaiyuki/Review/main/uplink.jsonld",
      "jsonSchema": "https://raw.githubusercontent.com/deaiyuki/Review/main/uplink.schema.json"
    }
  },
  "required": [
    "credentialSchema",
    "type",
    "credentialSubject",
    "expiration",
    "proofs"
  ],
  "properties": {
    "credentialSchema": {
      "type": "string",
      "format": "uri"
    },
    "type": {
      "oneOf": [
        {
          "type": "string",
          "const": "UPLinkCredential"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          },
          "contains": {
            "const": "UPLinkCredential"
          }
        }
      ]
    },
    "credentialSubject": {
      "type": "object",
      "required": [
        "id",
        "linkedPrivadoDid",
        "relationship",
        "linkageMethod",
        "linkedAt",
        "evidenceSummary"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^did:"
        },
        "linkedPrivadoDid": {
          "type": "string",
          "pattern": "^did:"
        },
        "relationship": {
          "type": "string"
        },
        "linkageMethod": {
          "type": "string"
        },
        "linkedAt": {
          "type": "string",
          "format": "date-time"
        },
        "evidenceSummary": {
          "type": "object",
          "required": [
            "upSignatureVerified",
            "privadoAuthenticationVerified"
          ],
          "properties": {
            "upSignatureVerified": {
              "type": "boolean"
            },
            "privadoAuthenticationVerified": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "expiration": {
      "type": "integer",
      "minimum": 0
    },
    "proof": {
      "type": "object"
    },
    "proofs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
